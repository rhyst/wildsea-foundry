<div id="aspects" class="flex0">
  <h2 class="wildsea-cut-corners wildsea-bg-dark">
    {{title}}
    <a class="wildsea-add-button" data-action="addItem" data-item-type="{{type}}">
      <i class="fas fa-plus"></i>
    </a>
  </h2>
  {{#if (any aspects)}}
    <div class="flexcol item-list wildsea-gapped">
      {{#each aspects as |aspect|}}
        {{> "systems/the-wildsea/templates/shared/aspect.hbs" aspect id=aspect.id type=type}}
      {{/each}}
    </div>
  {{else}}
    <p class="center wildsea-cut-corners wildsea-bg-muted wildsea-padded">{{localize "wildsea.none"}}</p>
  {{/if}}
</div>
