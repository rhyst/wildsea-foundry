<form class="wildsea flexcol spaced">
  <div class="form-group">
    <label>{{localize "wildsea.TRACKS.label"}}</label>
    <div class="form-fields">
      <input type="text" id="label" value="{{label}}" placeholder="{{localize "wildsea.TRACKS.label"}}" />
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "wildsea.TRACKS.trackGroups"}}</label>
    <div class="form-fields">
      <input type="text" id="groups" value="{{groups}}" placeholder="{{localize "wildsea.TRACKS.trackGroups"}}" />
      <small class="form-text">{{localize "wildsea.TRACKS.trackGroupsHelpText"}}</small>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "wildsea.TRACKS.visibility"}}</label>
    <div class="form-fields">
      <select name="visibility" id="visibility">
        {{#select visibility}}
        <option value="open">{{localize "wildsea.TRACKS.open"}}</option>
        <option value="hidden">{{localize "wildsea.TRACKS.hidden"}}</option>
        <option value="secret">{{localize "wildsea.TRACKS.secret"}}</option>
        {{/select}}
      </select>
    </div>
  </div>
</form>
