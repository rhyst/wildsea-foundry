<section class="wildsea track-panel {{position}}">
  <div class="track-list">
    {{#each tracks as |track|}}
      {{#if (or ../options.editable (ne track.visibility 'secret'))}}
      {{> "systems/the-wildsea/templates/applications/tracks/track.hbs" track=track}}
      {{/if}}
    {{/each}}
  </div>
  <div class="options text-right">
    {{#if options.editable}}
    <a class="wildsea-add-button" data-action="addTrack"><i class="fas fa-plus"></i> {{localize "wildsea.TRACKS.addTrack"}}</a>
    {{/if}}
  </div>
</section>
