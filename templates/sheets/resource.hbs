<form>
  <div class="flexcol wildsea-gapped">
    <div id="header" class="flexrow wildsea-gapped">
      <div class="flexrow wildsea-gapped">
        <div class="flex0 wildsea-portrait"><img src="{{item.img}}" data-edit="img" title="{{item.name}}" /></div>
        <div class="flexcol wildsea-gapped">
          <input id="name" class="wildsea-cut-corners" type="text" name="name" value="{{item.name}}" placeholder="{{localize "wildsea.name"}}" />
          <div class="flexrow wildsea-gapped">
            {{> "systems/the-wildsea/templates/shared/text_field.hbs" field="system.tags" label="wildsea.tags" value=system.tags}}
            {{> "systems/the-wildsea/templates/shared/select_field.hbs" field="system.type" label="wildsea.type" value=system.type includeEmpty=true selectOptions=config.resourceTypes}}
          </div>
        </div>
      </div>
    </div>
  </div>
</form>
