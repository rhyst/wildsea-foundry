<div class="mire flexrow" data-item-id="{{id}}">
  <div class="mireContextMenu">
    {{#if text}}
      <p>{{text}}</p>
    {{else}}
      <p><em>Missing</em></p>
    {{/if}}
  </div>
  <div class="flex0">
    {{> "systems/wildsea/templates/shared/track.hbs" max=track.max value=track.value type="mire"}}
  </div>
</div>
