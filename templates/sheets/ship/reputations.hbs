<div id="reputations" class="flex0">
  <h2 class="wildsea-cut-corners wildsea-bg-dark">
    {{localize "wildsea.reputation"}}
    <a class="wildsea-add-button" data-action="addItem" data-item-type="reputations">
      <i class="fas fa-plus"></i>
    </a>
  </h2>
  {{#if (any system.reputations)}}
    <div class="flexcol wildsea-gapped wildsea-compact-list">
      {{#each system.reputations as |reputation|}}
        {{> "systems/the-wildsea/templates/sheets/player/mire.hbs" reputation type="reputations"}}
      {{/each}}
    </div>
  {{else}}
    <p class="center wildsea-cut-corners wildsea-bg-muted wildsea-padded">{{localize "wildsea.none"}}</p>
  {{/if}}
</div>
